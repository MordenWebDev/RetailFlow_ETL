    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;UPDATE RETAIL_DW_DB.DW.DIM_CUSTOMER d SET is_current=FALSE, effective_end_dt=DATEADD('day',-1,CURRENT_DATE) FROM (SELECT customer_id,first_name,last_name,email,city,state,loyalty_tier,MD5(COALESCE(first_name,'')||'|'&#xD;&#xA;  ||COALESCE(last_name,'')||'|'||COALESCE(email,'')||'|'||COALESCE(city,'')||'|'||COALESCE(state,'')||'|'||COALESCE(loyalty_tier,'')) record_hash FROM RETAIL_DW_DB.DW.STG_CUSTOMER) s WHERE d.customer_id=s.customer_id&#xD;&#xA;  AND d.is_current=TRUE AND d.record_hash &lt;> s.record_hash&quot;"/>
