    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&#xD;&#xA;  &quot;INSERT INTO RETAIL_DW_DB.DW.DIM_CUSTOMER (customer_id,first_name,last_name,email,city,state,loyalty_tier,effective_start_dt,effective_end_dt,is_current,version,record_hash) &quot;&#xD;&#xA;  + &quot;SELECT s.customer_id,s.first_name,s.last_name,s.email,s.city,s.state,s.loyalty_tier,CURRENT_DATE,'9999-12-31'::DATE,TRUE,&quot;&#xD;&#xA;  + &quot;COALESCE((SELECT MAX(d2.version) FROM RETAIL_DW_DB.DW.DIM_CUSTOMER d2 WHERE d2.customer_id=s.customer_id),0)+1,s.record_hash &quot;&#xD;&#xA;  + &quot;FROM (SELECT customer_id,first_name,last_name,email,city,state,loyalty_tier,&quot;&#xD;&#xA;  + &quot;MD5(COALESCE(first_name,'')||'|'||COALESCE(last_name,'')||'|'||COALESCE(email,'')||'|'||COALESCE(city,'')||'|'||COALESCE(state,'')||'|'||COALESCE(loyalty_tier,'')) record_hash &quot;&#xD;&#xA;  + &quot;FROM RETAIL_DW_DB.DW.STG_CUSTOMER) s &quot;&#xD;&#xA;  + &quot;WHERE NOT EXISTS (SELECT 1 FROM RETAIL_DW_DB.DW.DIM_CUSTOMER d WHERE d.customer_id=s.customer_id AND d.is_current=TRUE)&quot;"/>
