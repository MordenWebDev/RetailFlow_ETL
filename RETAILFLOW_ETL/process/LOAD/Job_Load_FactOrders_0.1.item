    <elementParameter field="MEMO_SQL" name="configuration.dataSet.sqlQuery" value="&quot;SELECT oi.order_id, oi.item_id, oi.product_id, o.customer_id, o.store_id,&#xD;&#xA;    o.order_date::DATE order_date, UPPER(o.order_status) order_status, o.payment_method,&#xD;&#xA;    oi.quantity, oi.unit_price, oi.line_total,&#xD;&#xA;    ROUND(o.discount_amount*(oi.line_total/NULLIF(o.subtotal_amount,0)),2) discount_amount,&#xD;&#xA;    ROUND(o.tax_amount*(oi.line_total/NULLIF(o.subtotal_amount,0)),2) tax_amount,&#xD;&#xA;    ROUND(oi.line_total - ROUND(o.discount_amount*(oi.line_total/NULLIF(o.subtotal_amount,0)),2) +&#xD;&#xA;  ROUND(o.tax_amount*(oi.line_total/NULLIF(o.subtotal_amount,0)),2),2) net_amount,&#xD;&#xA;    TO_NUMBER(TO_CHAR(o.order_date,'YYYYMMDD')) date_sk&#xD;&#xA;  FROM RETAIL_RAW_DB.RAW.RAW_ORDER_ITEMS oi JOIN RETAIL_RAW_DB.RAW.RAW_ORDERS o ON o.order_id=oi.order_id&quot;"/>
