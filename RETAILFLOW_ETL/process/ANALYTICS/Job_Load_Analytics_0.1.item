    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="INSERT OVERWRITE INTO RETAIL_MART_DB.MART.CUSTOMER_360&#xD;&#xA;  (customer_id,full_name,city,state,loyalty_tier,total_orders,total_spend,avg_order_value,first_order_date,last_order_date,days_since_last) SELECT&#xD;&#xA;  dc.customer_id,dc.first_name||' '||dc.last_name,dc.city,dc.state,dc.loyalty_tier,COUNT(DISTINCT&#xD;&#xA;  f.order_id),SUM(f.net_amount),ROUND(SUM(f.net_amount)/NULLIF(COUNT(DISTINCT&#xD;&#xA;  f.order_id),0),2),MIN(f.order_date),MAX(f.order_date),DATEDIFF('day',MAX(f.order_date),CURRENT_DATE) FROM RETAIL_DW_DB.DW.FACT_ORDERS f JOIN&#xD;&#xA;  RETAIL_DW_DB.DW.DIM_CUSTOMER dc ON dc.customer_sk=f.customer_sk AND dc.is_current=TRUE GROUP BY 1,2,3,4,5"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
