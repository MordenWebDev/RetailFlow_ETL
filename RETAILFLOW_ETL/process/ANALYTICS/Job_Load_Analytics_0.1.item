    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.shareConnection" value="false" show="false"/>
    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value=" INSERT OVERWRITE INTO RETAIL_MART_DB.MART.SALES_SUMMARY_DAILY&#xD;&#xA;  (summary_date,store_id,store_name,region,total_orders,total_units,total_revenue,total_discount,total_tax,avg_order_value) SELECT&#xD;&#xA;  f.order_date,ds.store_id,ds.store_name,ds.region,COUNT(DISTINCT&#xD;&#xA;  f.order_id),SUM(f.quantity),SUM(f.net_amount),SUM(f.discount_amount),SUM(f.tax_amount),ROUND(SUM(f.net_amount)/NULLIF(COUNT(DISTINCT f.order_id),0),2) FROM&#xD;&#xA;  RETAIL_DW_DB.DW.FACT_ORDERS f JOIN RETAIL_DW_DB.DW.DIM_STORE ds ON ds.store_sk=f.store_sk GROUP BY 1,2,3,4"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.loginTimeout" value="15" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcUrlSuffix" value=".snowflakecomputing.com" show="false"/>
    <elementParameter field="CHECK" name="configuration.usePreparedStatement" value="false"/>
    <elementParameter field="TABLE" name="configuration.preparedStatementParameters" show="false"/>
    <elementParameter field="TEXT" name="configuration.commitEvery" value="10000"/>
