    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="INSERT OVERWRITE INTO RETAIL_MART_DB.MART.PRODUCT_PERFORMANCE (product_id,product_name,category,brand,total_qty_sold,total_revenue,total_orders) SELECT&#xD;&#xA;  dp.product_id,dp.product_name,dp.category,dp.brand,SUM(f.quantity),SUM(f.net_amount),COUNT(DISTINCT f.order_id) FROM RETAIL_DW_DB.DW.FACT_ORDERS f JOIN&#xD;&#xA;  RETAIL_DW_DB.DW.DIM_PRODUCT dp ON dp.product_sk=f.product_sk GROUP BY 1,2,3,4"/>
